# Timezone / runtime
TZ=Asia/Ho_Chi_Minh
LOG_LEVEL=INFO
PYTHONUNBUFFERED=1
PYTHONUTF8=1
PYTHONIOENCODING=utf-8
DATA_PATH=/app/data

# Selenium
# Local run with Docker Selenium Hub exposed on host:
SELENIUM_HOST=localhost
SELENIUM_PORT=4444
# Docker Compose overrides SELENIUM_HOST=selenium-hub internally for mb-fastapi.

# MB Business credentials - required for scheduler/startup.py
MB_USERNAME=
MB_PASSWORD=
MB_CORP_ID=
MB_LOGIN_MAX_ATTEMPTS=3
TRANSACTION_FETCH_INTERVAL=20
SESSION_RESTART_MINUTES=10

# Existing alternate MB Biz keys kept for compatibility with compose/deployment notes
MB_BIZ_USERNAME=
MB_BIZ_PASSWORD=
MB_BIZ_TAX_CODE=

# Lark keys used by schedule_module.py
APP_ID=
APP_SECRET=
TEST_14_CU=

# Existing alternate Lark keys
LARK_APP_ID=
LARK_APP_SECRET=
LARK_APP_TOKEN=
LARK_TABLE_ID=

# WooCommerce keys used by schedule_module.py
WOO_TEST_URL=
WOO_CONSUMER_KEY=
WOO_CONSUMER_SECRET=
WOO_SECURE_TOKEN=

# Existing alternate WooCommerce keys
WOOCOMMERCE_URL=
WOOCOMMERCE_CONSUMER_KEY=
WOOCOMMERCE_CONSUMER_SECRET=
